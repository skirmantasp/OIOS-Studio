{
  "name": "oios-studio",
  "version": "1.0.0",
  "description": "Internal workspace for Organizational Intelligence Architects — manage companies, assessments, discovery notes, insights, system ideas, projects, and reports.",
  "main": "index.html",
  "scripts": {
    "start": "node -e \"const {execFileSync}=require('child_process'),p=require('path');execFileSync(p.join('node_modules','.bin','serve'),['.','-l',process.env.PORT||'3000','--single'],{stdio:'inherit',shell:true})\"",
    "dev": "npx serve . -l 3000"
  },
  "dependencies": {
    "serve": "^14.2.4"
  },
  "keywords": [
    "oios",
    "organizational-intelligence",
    "architecture",
    "internal-tool"
  ],
  "author": "Organizational Intelligence Architect",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  }
}
